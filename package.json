{
  "name": "kiri",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "kiri": "./bin/kiri.ts"
  },
  "scripts": {
    "dev": "concurrently -n vite,server -c blue,green 'vite' 'bun --watch bin/kiri.ts'",
    "build": "vite build",
    "start": "bun bin/kiri.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^1.8.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
