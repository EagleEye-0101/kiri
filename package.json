{
  "name": "kiri",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "kiri": "./bin/kiri.ts"
  },
  "scripts": {
    "dev": "concurrently -n vite,server -c blue,green 'vite' 'bun --watch bin/kiri.ts'",
    "build": "vite build",
    "build:embed": "vite build && bun bin/generate-embedded-assets.ts",
    "start": "bun bin/kiri.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test src tests/integration",
    "test:e2e": "bun run build && playwright test",
    "db:generate": "drizzle-kit generate",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-vega": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "wouter": "^3.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^1.8.0",
    "msw": "^2.14.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
